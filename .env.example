# 服务器配置
PORT=3002
ALLOWED_ORIGINS=http://localhost:3002,http://127.0.0.1:3002

# 数据库配置（PostgreSQL）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aitutor

# JWT 密钥（生产环境请更换为随机强密钥）
JWT_SECRET=your-secret-key-here-please-change-in-production
JWT_EXPIRES_IN=7d

# AI 服务配置（可选）
LITELLM_API_KEY=
LITELLM_BASE_URL=

# GraphRAG 配置（可选）
GRAPHRAG_API_URL=
GRAPHRAG_API_KEY=

# Redis 配置（可选，不配置则使用内存缓存）
REDIS_URL=
