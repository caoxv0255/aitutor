{
  "name": "ai-tutor-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "start:win": "node server.js",
    "dev": "node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint api/ server.js tests/",
    "lint:fix": "eslint api/ server.js tests/ --fix",
    "format": "prettier --write \"api/**/*.js\" server.js \"tests/**/*.js\"",
    "format:check": "prettier --check \"api/**/*.js\" server.js \"tests/**/*.js\""
  },
  "dependencies": {
    "axios": "^1.16.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dompurify": "^3.3.1",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "jsdom": "^29.1.1",
    "jsonwebtoken": "^9.0.3",
    "katex": "^0.16.33",
    "marked": "^17.0.4",
    "pg": "^8.13.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-prettier": "^5.5.6",
    "gitnexus": "^1.6.5",
    "jimp": "^1.6.1",
    "prettier": "^3.8.3",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "vitest": "^4.1.8"
  }
}
