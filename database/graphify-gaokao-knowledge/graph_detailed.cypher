WITH kp MATCH (ch:Chapter {name: '4．影响化学平衡的条件', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '③温度：升高温度，平衡向吸热反应方向移动。降低温度，平衡向放热反应方向移动。', chapter: '4．影响化学平衡的条件', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '4．影响化学平衡的条件', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '④催化剂：不能影响平衡移动。', chapter: '4．影响化学平衡的条件', subject: '化学'})
