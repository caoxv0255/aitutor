MERGE (kp:KnowledgePoint {name: '②电解质溶液中：盐酸、NaOH溶液…', chapter: '3．离子', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '3．离子', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '③金属晶体中：钠、铁、钾、铜…', chapter: '3．离子', subject: '化学'})
