WITH kp MATCH (ch:Chapter {name: '2.1.2系统抽样', subject: '数学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '明样本在总体中的分布承某种循环性规律，且这种循环和抽样距离重合。', chapter: '2.1.2系统抽样', subject: '数学'})
WITH kp MATCH (ch:Chapter {name: '2.1.2系统抽样', subject: '数学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
