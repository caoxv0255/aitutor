// 高中知识点归纳汇总 - 细粒度知识图谱
// 共 9 个学科, 1583 个章节

MERGE (:Root {name: '高中知识点归纳汇总'})

MERGE (s:Subject {name: '化学', level: 'gaokao', type: '知识点归纳'})
WITH s MATCH (r:Root {name: '高中知识点归纳汇总'}) MERGE (r)-[:HAS_SUBJECT]->(s)

MERGE (ch:Chapter {name: '第一部分 化学基本概念和基本理论', subject: '化学'})
WITH ch MATCH (s:Subject {name: '化学', level: 'gaokao'}) MERGE (s)-[:HAS_CHAPTER]->(ch)
MERGE (kp:KnowledgePoint {name: '一．物质的组成、性质和分类：', chapter: '第一部分 化学基本概念和基本理论', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '第一部分 化学基本概念和基本理论', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '（一）掌握基本概念', chapter: '第一部分 化学基本概念和基本理论', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '第一部分 化学基本概念和基本理论', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)

MERGE (ch:Chapter {name: '1．分子', subject: '化学'})
WITH ch MATCH (s:Subject {name: '化学', level: 'gaokao'}) MERGE (s)-[:HAS_CHAPTER]->(ch)
MERGE (kp:KnowledgePoint {name: '分子是能够独立存在并保持物质化学性质的一种微粒。', chapter: '1．分子', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '1．分子', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '（1）分子同原子、离子一样是构成物质的基本微粒．', chapter: '1．分子', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '1．分子', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '（2）按组成分子的原子个数可分为：', chapter: '1．分子', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '1．分子', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '单原子分子如：He、Ne、Ar、Kr…', chapter: '1．分子', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '1．分子', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '双原子分子如：O、H、HCl、NO…', chapter: '1．分子', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '1．分子', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '多原子分子如：HO、P、CH O…', chapter: '1．分子', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '1．分子', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '2 4 6 12 6', chapter: '1．分子', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '1．分子', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)

MERGE (ch:Chapter {name: '2．原子', subject: '化学'})
WITH ch MATCH (s:Subject {name: '化学', level: 'gaokao'}) MERGE (s)-[:HAS_CHAPTER]->(ch)
MERGE (kp:KnowledgePoint {name: '原子是化学变化中的最小微粒。确切地说，在化学反应中原子核不变，只有核外电子发生变化。', chapter: '2．原子', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '2．原子', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '（1）原子是组成某些物质（如金刚石、晶体硅、二氧化硅等原子晶体）和分子的基本微粒。', chapter: '2．原子', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '2．原子', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '（2）原子是由原子核（中子、质子）和核外电子构成的。', chapter: '2．原子', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '2．原子', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)

