MERGE (ch:Chapter {name: '4．元素', subject: '化学'})
WITH ch MATCH (s:Subject {name: '化学', level: 'gaokao'}) MERGE (s)-[:HAS_CHAPTER]->(ch)
MERGE (kp:KnowledgePoint {name: '元素是具有相同核电荷数（即质子数）的同—类原子的总称。', chapter: '4．元素', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '4．元素', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '（1）元素与物质、分子、原子的区别与联系：物质是由元素组成的（宏观看）；物质是由分子、原子', chapter: '4．元素', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '4．元素', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '或离子构成的（微观看）。', chapter: '4．元素', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '4．元素', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '（2）某些元素可以形成不同的单质（性质、结构不同）—同素异形体。', chapter: '4．元素', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '4．元素', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '（3）各种元素在地壳中的质量分数各不相同，占前五位的依次是：O、Si、Al、Fe、Ca。', chapter: '4．元素', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '4．元素', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)

MERGE (ch:Chapter {name: '5．同位素', subject: '化学'})
WITH ch MATCH (s:Subject {name: '化学', level: 'gaokao'}) MERGE (s)-[:HAS_CHAPTER]->(ch)
MERGE (kp:KnowledgePoint {name: '是指同一元素不同核素之间互称同位素，即具有相同质子数，不同中子数的同一类原子互称同位素。', chapter: '5．同位素', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '5．同位素', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '如H有三种同位素：1H、2H、3H（氕、氘、氚）。', chapter: '5．同位素', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '5．同位素', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)

MERGE (ch:Chapter {name: '6．核素', subject: '化学'})
WITH ch MATCH (s:Subject {name: '化学', level: 'gaokao'}) MERGE (s)-[:HAS_CHAPTER]->(ch)
MERGE (kp:KnowledgePoint {name: '核素是具有特定质量数、原子序数和核能态，而且其寿命足以被观察的一类原子。', chapter: '6．核素', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '6．核素', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '（1）同种元素、可以有若干种不同的核素—同位素。', chapter: '6．核素', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '6．核素', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '（2）同一种元素的各种核素尽管中子数不同，但它们的质子数和电子数相同。核外电子排布相同，因', chapter: '6．核素', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '6．核素', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '而它们的化学性质几乎是相同的。', chapter: '6．核素', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '6．核素', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)

MERGE (ch:Chapter {name: '7．原子团', subject: '化学'})
WITH ch MATCH (s:Subject {name: '化学', level: 'gaokao'}) MERGE (s)-[:HAS_CHAPTER]->(ch)
MERGE (kp:KnowledgePoint {name: '原子团是指多个原子结合成的集体，在许多反应中，原子团作为一个集体参加反应。原子团有几下几', chapter: '7．原子团', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '7．原子团', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '种类型：根（如SO2-、OHˉ、CHCOOˉ等）、官能团（有机物分子中能反映物质特殊性质的原子团，如—OH、', chapter: '7．原子团', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '7．原子团', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '—NO、—COOH等）、游离基（又称自由基、具有不成价电子的原子团，如甲基游离基 · CH）。', chapter: '7．原子团', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '7．原子团', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)

MERGE (ch:Chapter {name: '8．基', subject: '化学'})
WITH ch MATCH (s:Subject {name: '化学', level: 'gaokao'}) MERGE (s)-[:HAS_CHAPTER]->(ch)
MERGE (kp:KnowledgePoint {name: '化合物中具有特殊性质的一部分原子或原子团，或化合物分子中去掉某些原子或原子团后剩下的原子', chapter: '8．基', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '8．基', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '（1）有机物的官能团是决定物质主要性质的基，如醇的羟基（—OH）和羧酸的羧基（—COOH）。', chapter: '8．基', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '8．基', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '（2）甲烷（CH）分子去掉一个氢原子后剩余部分（· CH）含有未成对的价电子，称甲基或甲基游离', chapter: '8．基', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '8．基', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '基，也包括单原子的游离基（· Cl）。', chapter: '8．基', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '8．基', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '第 1 页 共 43 页', chapter: '8．基', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '8．基', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '基（羟基） 根（氢氧根）', chapter: '8．基', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '8．基', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '电性 电中性 带负电', chapter: '8．基', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '8．基', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '不能独立存在，必须和其他“基”或原子团相结', chapter: '8．基', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '8．基', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '存在于 能独立存在于溶液或离子化合物中', chapter: '8．基', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '8．基', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)

MERGE (ch:Chapter {name: '9．物理性质与化学性质', subject: '化学'})
WITH ch MATCH (s:Subject {name: '化学', level: 'gaokao'}) MERGE (s)-[:HAS_CHAPTER]->(ch)
MERGE (kp:KnowledgePoint {name: '物理性质 化学性质', chapter: '9．物理性质与化学性质', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '9．物理性质与化学性质', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '概念 物质不需要发生化学变化就能表现出来的', chapter: '9．物理性质与化学性质', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '9．物理性质与化学性质', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '物质在发生化学变化时表现出来的性质', chapter: '9．物理性质与化学性质', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '9．物理性质与化学性质', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '（宏观） 性质', chapter: '9．物理性质与化学性质', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '9．物理性质与化学性质', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '实质 物质的分子组成和结构没有发生改变时呈 物质的分子组成和结构发生改变时呈现的性', chapter: '9．物理性质与化学性质', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '9．物理性质与化学性质', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '（微观） 现的性质 质', chapter: '9．物理性质与化学性质', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '9．物理性质与化学性质', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '性质包 颜色、状态、气味、味道、密度、熔点、 一般指跟氢气、氧气、金属、非金属、氧化', chapter: '9．物理性质与化学性质', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '9．物理性质与化学性质', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '括内容 沸点、溶解性、导电性、导热性等 物、酸、碱、盐能否发生反应及热稳定性等', chapter: '9．物理性质与化学性质', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '9．物理性质与化学性质', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)

MERGE (ch:Chapter {name: '9．物理变化和化学变化', subject: '化学'})
WITH ch MATCH (s:Subject {name: '化学', level: 'gaokao'}) MERGE (s)-[:HAS_CHAPTER]->(ch)
MERGE (kp:KnowledgePoint {name: '物理变化：没有生成其他物质的变化，仅是物质形态的变化。', chapter: '9．物理变化和化学变化', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '9．物理变化和化学变化', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '化学变化：变化时有其他物质生成，又叫化学反应。', chapter: '9．物理变化和化学变化', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '9．物理变化和化学变化', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '化学变化的特征：有新物质生成伴有放热、发光、变色等现象', chapter: '9．物理变化和化学变化', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '9．物理变化和化学变化', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '化学变化本质：旧键断裂、新键生成或转移电子等。二者的区别是：前者无新物质生成，仅是物质形', chapter: '9．物理变化和化学变化', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '9．物理变化和化学变化', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '态、状态的变化。', chapter: '9．物理变化和化学变化', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '9．物理变化和化学变化', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)

MERGE (ch:Chapter {name: '10．溶解性', subject: '化学'})
WITH ch MATCH (s:Subject {name: '化学', level: 'gaokao'}) MERGE (s)-[:HAS_CHAPTER]->(ch)
MERGE (kp:KnowledgePoint {name: '指物质在某种溶剂中溶解的能力。例如氯化钠易溶于水，却难溶于无水乙醇、苯等有机溶剂。单质碘', chapter: '10．溶解性', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '10．溶解性', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '在水中溶解性较差，却易溶于乙醇、苯等有机溶剂。苯酚在室温时仅微溶于水，当温度大于70℃时，却能', chapter: '10．溶解性', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '10．溶解性', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '以任意比与水互溶（苯酚熔点为43℃，70℃时苯酚为液态）。利用物质在不同温度或不同溶剂中溶解性的', chapter: '10．溶解性', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '10．溶解性', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '差异，可以分离混合物或进行物质的提纯。', chapter: '10．溶解性', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '10．溶解性', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '在上述物质溶解过程中，溶质与溶剂的化学组成没有发生变化，利用简单的物理方法可以把溶质与溶', chapter: '10．溶解性', subject: '化学'})
WITH kp MATCH (ch:Chapter {name: '10．溶解性', subject: '化学'}) MERGE (ch)-[:HAS_KNOWLEDGE_POINT]->(kp)
MERGE (kp:KnowledgePoint {name: '剂分离开。还有一种完全不同意义的溶解。例如，石灰石溶于盐酸，铁溶于稀硫酸，氢氧化银溶于氨水等。', chapter: '10．溶解性', subject: '化学'})
