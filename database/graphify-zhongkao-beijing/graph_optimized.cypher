MERGE (o:Option {label: 'B', text: '召开（zhào kāi）：召集人们开会；举行（会议）。文中指全国新华书店第一届出版工作会议举行。', question_id: 'bj_语文_2025_15'})
WITH o MATCH (q:Question {id: 'bj_语文_2025_15'}) MERGE (q)-[:HAS_OPTION]->(o)
