WITH o MATCH (q:Question {id: 'bj_物理_2024_11'}) MERGE (q)-[:HAS_OPTION]->(o)
MERGE (o:Option {label: 'B', text: '增大阻力臂，方便使用', question_id: 'bj_物理_2024_11'})
