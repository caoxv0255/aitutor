MERGE (o:Option {label: 'C', text: '减小动力臂，方便使用', question_id: 'bj_物理_2024_11'})
WITH o MATCH (q:Question {id: 'bj_物理_2024_11'}) MERGE (q)-[:HAS_OPTION]->(o)
MERGE (o:Option {label: 'D', text: '减小阻力臂，能够省力
【答案】D
【解析】
【详解】常把枝条尽量往剪刀的轴处靠近，阻力臂减小了，阻力与阻力臂的乘积减小，动力臂不变，则动力减小，能够省力，故D符合题意，ABC不符合题意。
故选D。', question_id: 'bj_物理_2024_11'})
