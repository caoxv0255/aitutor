WITH q MATCH (p:Paper {name: '2024年北京市中考语文真题（空白卷）.docx'}) MERGE (p)-[:HAS_QUESTION]->(q)
MERGE (q:Question {id: '语文_2024_10', title: '8. 默写', content: '（1）最爱湖东行不足，________。（白居易《钱塘湖春行》） （2）博学而笃志，切问而近思，________。（《论语·子张》） （3）古诗文中那些闪耀着思想光芒的句子，不断让我们获得启迪和教益，如“________，________”。（本试卷中出现的句子除外）', subject: '语文', year: '2024'})
